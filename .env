## Docker Compose env (dev/local)
##
## ВАЖНО:
## - Если у вас уже был создан volume Postgres (pgdata), пароль БД уже "запечатан" внутри него.
##   Поэтому по умолчанию оставляем POSTGRES_PASSWORD=master_print (как в старом примере),
##   чтобы бэкенд смог подключиться и подняться без удаления данных.

POSTGRES_DB=master_print
POSTGRES_USER=master_print
POSTGRES_PASSWORD=master_print

DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_SECRET_KEY=change-me-change-me-change-me-change-me

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
JWT_ACCESS_COOKIE_NAME=mp_access_token
JWT_REFRESH_COOKIE_NAME=mp_refresh_token
JWT_COOKIE_SAMESITE=Strict
JWT_COOKIE_SECURE=0

DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=300/min
DRF_THROTTLE_LOGIN=5/m

UPLOAD_MAX_FILE_SIZE_BYTES=10485760
UPLOAD_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf
UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,application/pdf

# Для "полной" защиты ПД (шифрование в БД): задайте base64url ключ на 32 байта.
# Пример формата: PII_ENCRYPTION_KEY=6i7Yk4... (без пробелов)
PII_ENCRYPTION_KEY=

